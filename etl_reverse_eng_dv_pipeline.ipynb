    "---\n",
    "# Agent 6 — Data Reconciliation\n",
    "Generates reconciliation SQL queries and recommendations for source → target validation."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "RECON_TEMPLATE = Template(\"\"\"\n",
    "-- ============================================================\n",
    "-- RECONCILIATION: {{ mapping_name }}\n",
    "-- Source : {{ source_table }}\n",
    "-- Target : {{ target_table }}\n",
    "-- Generated by gokulram.krishnan | {{ run_ts }}\n",
    "-- ============================================================\n",
    "\n",
    "-- 1. ROW COUNT RECONCILIATION\n",
    "SELECT\n",
    "    'SOURCE' AS layer,\n",
    "    COUNT(*) AS row_count\n",
    "FROM {{ source_table }}\n",
    "UNION ALL\n",
    "SELECT\n",
    "    'TARGET' AS layer,\n",
    "    COUNT(*) AS row_count\n",
    "FROM {{ target_table }};\n",
    "\n",
    "-- 2. NULL CHECK RECONCILIATION\n",
    "SELECT\n",
    "    'SOURCE' AS layer,\n",
    "{% for col in pk_cols %}\n",
    "    SUM(CASE WHEN {{ col }} IS NULL THEN 1 ELSE 0 END) AS null_{{ col }}_count{{ \",\" if not loop.last else \"\" }}\n",
    "{% endfor %}\n",
    "FROM {{ source_table }}\n",
    "UNION ALL\n",
    "SELECT\n",
    "    'TARGET' AS layer,\n",
    "{% for col in pk_cols %}\n",
    "    SUM(CASE WHEN {{ col }} IS NULL THEN 1 ELSE 0 END) AS null_{{ col }}_count{{ \",\" if not loop.last else \"\" }}\n",
    "{% endfor %}\n",
    "FROM {{ target_table }};\n",
    "\n",
    "-- 3. NUMERIC CHECKSUM RECONCILIATION\n",
    "{% if numeric_cols %}\n",
    "SELECT\n",
    "    'SOURCE' AS layer,\n",
    "{% for col in numeric_cols %}\n",
    "    SUM({{ col }}) AS sum_{{ col }},\n",
    "    AVG({{ col }}) AS avg_{{ col }}{{ \",\" if not loop.last else \"\" }}\n",
    "{% endfor %}\n",
    "FROM {{ source_table }}\n",
    "UNION ALL\n",
    "SELECT\n",
    "    'TARGET' AS layer,\n",
    "{% for col in numeric_cols %}\n",
    "    SUM({{ col }}) AS sum_{{ col }},\n",
    "    AVG({{ col }}) AS avg_{{ col }}{{ \",\" if not loop.last else \"\" }}\n",
    "{% endfor %}\n",
    "FROM {{ target_table }};\n",
    "{% endif %}\n",
    "\n",
    "-- 4. DUPLICATE KEY CHECK (TARGET)\n",
    "SELECT\n",
    "    {{ pk_cols | join(\", \") }},\n",
    "    COUNT(*) AS duplicate_count\n",
    "FROM {{ target_table }}\n",
    "GROUP BY {{ pk_cols | join(\", \") }}\n",
    "HAVING COUNT(*) > 1\n",
    "LIMIT 100;\n",
    "\n",
    "-- 5. MISSING RECORDS (in source but not target)\n",
    "SELECT s.{{ pk_cols[0] }}\n",
    "FROM {{ source_table }} s\n",
    "LEFT JOIN {{ target_table }} t ON s.{{ pk_cols[0] }} = t.{{ pk_cols[0] }}\n",
    "WHERE t.{{ pk_cols[0] }} IS NULL\n",
    "LIMIT 100;\n",
    "\n",
    "-- 6. EXTRA RECORDS (in target but not source)\n",
    "SELECT t.{{ pk_cols[0] }}\n",
    "FROM {{ target_table }} t\n",
    "LEFT JOIN {{ source_table }} s ON t.{{ pk_cols[0] }} = s.{{ pk_cols[0] }}\n",
    "WHERE s.{{ pk_cols[0] }} IS NULL\n",
    "LIMIT 100;\n",
    "\"\"\")\n",
    "\n",
    "\n",
    "def run_agent6_reconciliation(mappings: list) -> list:\n",
    "    \"\"\"\n",
    "    Agent 6: Generate reconciliation SQL + recommendations for each mapping.\n",
    "    \"\"\"\n",
    "    recommendations = []\n",
    "\n",
    "    for m in mappings:\n",
    "        pk_cols  = [c[\"tgt\"] for c in m[\"columns\"] if c[\"pk\"]]\n",
    "        num_cols = [c[\"tgt\"] for c in m[\"columns\"]\n",
    "                    if any(t in c[\"dtype\"].upper() for t in [\"NUMBER\",\"FLOAT\",\"INT\",\"DECIMAL\",\"NUMERIC\"])]\n",
    "\n",
    "        if not pk_cols:\n",
    "            pk_cols = [m[\"columns\"][0][\"tgt\"]]  # fallback to first column\n",
    "\n",
    "        # Generate SQL\n",
    "        sql = RECON_TEMPLATE.render(\n",
    "            mapping_name = m[\"mapping_name\"],\n",
    "            source_table = m[\"source_table\"],\n",
    "            target_table = m[\"target_table\"],\n",
    "            pk_cols      = pk_cols,\n",
    "            numeric_cols = num_cols,\n",
    "            run_ts       = RUN_TS,\n",
    "        )\n",
    "        sql_path = OUTPUT_DIR / \"reconciliation\" / f\"recon_{m['mapping_name']}.sql\"\n",
    "        sql_path.write_text(sql)\n",
    "\n",
    "        # Recommendations\n",
    "        rec = {\n",
    "            \"mapping\":         m[\"mapping_name\"],\n",
    "            \"source\":          m[\"source_table\"],\n",
    "            \"target\":          m[\"target_table\"],\n",
    "            \"sql_file\":        str(sql_path),\n",
    "            \"recommendations\": [\n",
    "                \"✅ Run row-count check before and after each load\",\n",
    "                \"✅ Validate checksum on all numeric columns post-load\",\n",
    "                f\"✅ Assert uniqueness on PK columns: {', '.join(pk_cols)}\",\n",
    "                \"✅ Schedule reconciliation as a dbt test (dbt test --select <model>)\",\n",
    "                \"✅ Use dbt's audit_helper package for detailed column-level comparison\",\n",
    "                \"✅ Store recon results in a Snowflake audit table for trending\",\n",
    "                \"⚠️  For incremental loads: reconcile only the delta window, not full table\",\n",
    "                \"⚠️  For Data Vault: row counts will differ due to insert-only pattern — compare business key counts instead\",\n",
    "            ]\n",
    "        }\n",
    "        if num_cols:\n",
    "            rec[\"recommendations\"].append(\n",
    "                f\"✅ Numeric checksum columns identified: {', '.join(num_cols)}\"\n",
    "            )\n",
    "        recommendations.append(rec)\n",
    "        log(\"Agent6\", f\"Recon SQL → {sql_path.name}\")\n",
    "\n",
    "    out = OUTPUT_DIR / \"reconciliation\" / \"recon_recommendations.json\"\n",
    "    out.write_text(json.dumps(recommendations, indent=2))\n",
    "    log(\"Agent6\", f\"✅ Reconciliation complete → {out}\")\n",
    "    return recommendations\n",
    "\n",
    "\n",
    "RECON_RESULTS = run_agent6_reconciliation(MAPPINGS)\n",
    "\n",
    "for r in RECON_RESULTS:\n",
    "    print(f\"\\n{'─'*60}\")\n",
    "    print(f\"Mapping: {r['mapping']}  |  {r['source']} → {r['target']}\")\n",
    "    for rec in r[\"recommendations\"]:\n",
    "        print(f\"  {rec}\")"
   ]
  },
