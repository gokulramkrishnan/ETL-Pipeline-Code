    "# ── Jinja2 templates aligned to datavault4dbt v1.17.0 ─────────────────────────\n",
    "\n",
    "STAGING_TEMPLATE = Template(\"\"\"\n",
    "{{%- set yaml_metadata -%}}\n",
    "source_model: '{{ stg.source_table }}'\n",
    "hashed_columns:\n",
    "  {{ stg.hash_key }}:\n",
    "    - {{ stg.bk_columns | join(\"\\n    - \") }}\n",
    "  {{ stg.hash_diff }}:\n",
    "    is_hashdiff: true\n",
    "    columns:\n",
    "      - {{ stg.desc_columns | join(\"\\n      - \") }}\n",
    "{{%- endset -%}}\n",
    "\n",
    "{{%- set metadata_dict = fromyaml(yaml_metadata) -%}}\n",
    "\n",
    "{{ datavault4dbt.stage(source_model=metadata_dict['source_model'],\n",
    "                       hashed_columns=metadata_dict['hashed_columns']) }}\n",
    "\"\"\"\n",
    ")\n",
    "\n",
    "HUB_TEMPLATE = Template(\"\"\"\n",
    "{{%- set yaml_metadata -%}}\n",
    "source_model: 'stg_{{ entity | lower }}'\n",
    "src_pk: '{{ hub.hash_key }}'\n",
    "src_nk: '{{ hub.business_key }}'\n",
    "src_ldts: '{{ hub.load_date_col }}'\n",
    "src_source: '{{ hub.record_src_col }}'\n",
    "{{%- endset -%}}\n",
    "\n",
    "{{%- set metadata_dict = fromyaml(yaml_metadata) -%}}\n",
    "\n",
    "{{ datavault4dbt.hub(source_model=metadata_dict['source_model'],\n",
    "                     src_pk=metadata_dict['src_pk'],\n",
    "                     src_nk=metadata_dict['src_nk'],\n",
    "                     src_ldts=metadata_dict['src_ldts'],\n",
    "                     src_source=metadata_dict['src_source']) }}\n",
    "\"\"\"\n",
    ")\n",
    "\n",
    "LINK_TEMPLATE = Template(\"\"\"\n",
    "{{%- set yaml_metadata -%}}\n",
    "source_model: {{ lnk.source_tables | tojson }}\n",
    "src_pk: '{{ lnk.hash_key }}'\n",
    "src_fk:\n",
    "  - {{ lnk.fk_hash_keys | join(\"\\n  - \") }}\n",
    "src_ldts: 'LOAD_DATE'\n",
    "src_source: 'RECORD_SOURCE'\n",
    "{{%- endset -%}}\n",
    "\n",
    "{{%- set metadata_dict = fromyaml(yaml_metadata) -%}}\n",
    "\n",
    "{{ datavault4dbt.link(source_model=metadata_dict['source_model'],\n",
    "                      src_pk=metadata_dict['src_pk'],\n",
    "                      src_fk=metadata_dict['src_fk'],\n",
    "                      src_ldts=metadata_dict['src_ldts'],\n",
    "                      src_source=metadata_dict['src_source']) }}\n",
    "\"\"\"\n",
    ")\n",
    "\n",
    "SAT_TEMPLATE = Template(\"\"\"\n",
    "{{%- set yaml_metadata -%}}\n",
    "source_model: 'stg_{{ entity | lower }}'\n",
    "src_pk: '{{ sat.hash_key }}'\n",
    "src_hashdiff: '{{ sat.hash_diff }}'\n",
    "src_payload:\n",
    "  - {{ sat.descriptive_cols | join(\"\\n  - \") }}\n",
    "src_ldts: '{{ sat.load_date_col }}'\n",
    "src_source: '{{ sat.record_src_col }}'\n",
    "{{%- endset -%}}\n",
    "\n",
    "{{%- set metadata_dict = fromyaml(yaml_metadata) -%}}\n",
    "\n",
    "{{ datavault4dbt.sat(source_model=metadata_dict['source_model'],\n",
    "                     src_pk=metadata_dict['src_pk'],\n",
    "                     src_hashdiff=metadata_dict['src_hashdiff'],\n",
    "                     src_payload=metadata_dict['src_payload'],\n",
    "                     src_ldts=metadata_dict['src_ldts'],\n",
    "                     src_source=metadata_dict['src_source']) }}\n",
    "\"\"\"\n",
    ")\n",
    "\n",
    "\n",
    "def run_agent4_dbt_generator(mappings: list, dv_model: dict) -> dict:\n",
    "    \"\"\"\n",
    "    Agent 4: Generate all dbt model files + project configuration.\n",
    "    Outputs:\n",
    "      - dbt_project.yml\n",
    "      - packages.yml (with datavault4dbt v1.17.0)\n",
    "      - profiles.yml (Snowflake)\n",
    "      - models/staging/stg_<entity>.sql\n",
    "      - models/raw_vault/hub_<entity>.sql\n",
    "      - models/raw_vault/lnk_<entity>.sql\n",
    "      - models/raw_vault/sat_<entity>.sql\n",
    "      - models/staging/sources.yml\n",
    "      - models/raw_vault/schema.yml\n",
    "    \"\"\"\n",
    "    dbt_dir = OUTPUT_DIR / \"dbt\"\n",
    "    generated = {\"staging\": [], \"hubs\": [], \"links\": [], \"satellites\": [], \"configs\": []}\n",
    "\n",
    "    # ── dbt_project.yml ───────────────────────────────────────────────────────\n",
    "    dbt_project = {\n",
    "        \"name\":    DBT_PROJECT_NAME,\n",
    "        \"version\": \"1.0.0\",\n",
    "        \"profile\": DBT_PROFILE_NAME,\n",
    "        \"model-paths\": [\"models\"],\n",
    "        \"vars\": {\n",
    "            \"datavault4dbt\": {\n",
    "                \"hash\":           HASH_ALGO,\n",
    "                \"concat_char\":    \"|\",\n",
    "                \"hash_dtype\":     \"string\",\n",
    "                \"timestamp_dtype\":\"timestamp\",\n",
    "                \"multiactive_source_label\": \"RECORD_SOURCE\",\n",
    "                \"load_date\":      \"LOAD_DATE\",\n",
    "                \"record_source\":  \"RECORD_SOURCE\",\n",
    "                \"ghost_record_type\": \"VARCHAR(1)\",\n",
    "            }\n",
    "        },\n",
    "        \"models\": {\n",
    "            DBT_PROJECT_NAME: {\n",
    "                \"staging\":       {\"schema\": DV_SCHEMA_STG,  \"materialized\": \"view\"},\n",
    "                \"raw_vault\":     {\"schema\": DV_SCHEMA_RAW,  \"materialized\": \"incremental\"},\n",
    "                \"business_vault\":{\"schema\": DV_SCHEMA_BIZ,  \"materialized\": \"table\"},\n",
    "            }\n",
    "        }\n",
    "    }\n",
    "    p = dbt_dir / \"dbt_project.yml\"\n",
    "    p.write_text(yaml.dump(dbt_project, sort_keys=False))\n",
    "    generated[\"configs\"].append(str(p))\n",
    "\n",
    "    # ── packages.yml ──────────────────────────────────────────────────────────\n",
    "    packages = {\"packages\": [{\"package\": \"ScalefreeCOM/datavault4dbt\", \"version\": \"1.17.0\"}]}\n",
    "    p = dbt_dir / \"packages.yml\"\n",
    "    p.write_text(yaml.dump(packages))\n",
    "    generated[\"configs\"].append(str(p))\n",
    "\n",
    "    # ── profiles.yml (Snowflake) ──────────────────────────────────────────────\n",
    "    profiles = {\n",
    "        DBT_PROFILE_NAME: {\n",
    "            \"target\": \"dev\",\n",
    "            \"outputs\": {\n",
    "                \"dev\": {\n",
    "                    \"type\":      \"snowflake\",\n",
    "                    \"account\":   SNOWFLAKE_CONFIG[\"account\"],\n",
    "                    \"user\":      SNOWFLAKE_CONFIG[\"user\"],\n",
    "                    \"password\":  SNOWFLAKE_CONFIG[\"password\"],\n",
    "                    \"role\":      SNOWFLAKE_CONFIG[\"role\"],\n",
    "                    \"database\":  SNOWFLAKE_CONFIG[\"database\"],\n",
    "                    \"warehouse\": SNOWFLAKE_CONFIG[\"warehouse\"],\n",
    "                    \"schema\":    DV_SCHEMA_STG,\n",
    "                    \"threads\":   4,\n",
    "                }\n",
    "            }\n",
    "        }\n",
    "    }\n",
    "    p = dbt_dir / \"profiles.yml\"\n",
    "    p.write_text(yaml.dump(profiles, sort_keys=False))\n",
    "    generated[\"configs\"].append(str(p))\n",
    "\n",
    "    # ── Staging models ────────────────────────────────────────────────────────\n",
    "    sources_yml = {\"version\": 2, \"sources\": []}\n",
    "    for stg in dv_model[\"staging\"]:\n",
    "        entity    = stg[\"table_name\"].replace(\"STG_\",\"\")\n",
    "        bk_cols   = stg[\"bk_columns\"]\n",
    "        desc_cols = [c[\"tgt\"] for c in stg[\"all_columns\"]\n",
    "                     if c[\"tgt\"] not in bk_cols\n",
    "                     and c[\"tgt\"] not in (\"LOAD_DATE\",\"RECORD_SOURCE\")]\n",
    "\n",
    "        stg_sql = f\"\"\"-- Staging model for {entity}\n",
    "-- datavault4dbt v1.17.0 | Snowflake | Generated by gokulram.krishnan\n",
    "{{% set yaml_metadata -%}}\n",
    "source_model: ref('{stg['source_mapping']}')\n",
    "hashed_columns:\n",
    "  HK_{entity}:\n",
    "    - {chr(10) + '    - '.join(bk_cols) if bk_cols else 'UNKNOWN_BK'}\n",
    "  HD_{entity}:\n",
    "    is_hashdiff: true\n",
    "    columns:\n",
    "      - {chr(10) + '      - '.join(desc_cols) if desc_cols else 'UNKNOWN_DESC'}\n",
    "{{%- endset %}}\n",
    "{{%- set metadata_dict = fromyaml(yaml_metadata) -%}}\n",
    "\n",
    "{{{{ datavault4dbt.stage(\n",
    "    source_model=metadata_dict['source_model'],\n",
    "    hashed_columns=metadata_dict['hashed_columns']\n",
    ") }}}}\n",
    "\"\"\"\n",
    "        fname = dbt_dir / \"models\" / \"staging\" / f\"stg_{entity.lower()}.sql\"\n",
    "        fname.write_text(stg_sql)\n",
    "        generated[\"staging\"].append(str(fname))\n",
    "\n",
    "        # Sources YAML entry\n",
    "        src_name = stg[\"source_table\"].split(\".\")[0] if \".\" in stg[\"source_table\"] else \"SOURCE\"\n",
    "        tbl_name = stg[\"source_table\"].split(\".\")[-1]\n",
    "        existing = next((s for s in sources_yml[\"sources\"] if s[\"name\"]==src_name), None)\n",
    "        if not existing:\n",
    "            existing = {\"name\": src_name, \"tables\": []}\n",
    "            sources_yml[\"sources\"].append(existing)\n",
    "        existing[\"tables\"].append({\"name\": tbl_name})\n",
    "\n",
    "    src_yaml_path = dbt_dir / \"models\" / \"staging\" / \"sources.yml\"\n",
    "    src_yaml_path.write_text(yaml.dump(sources_yml, sort_keys=False))\n",
    "    generated[\"configs\"].append(str(src_yaml_path))\n",
    "\n",
    "    # ── Hub models ────────────────────────────────────────────────────────────\n",
    "    schema_yml = {\"version\": 2, \"models\": []}\n",
    "    for hub in dv_model[\"hubs\"]:\n",
    "        entity  = hub[\"entity\"]\n",
    "        hub_sql = f\"\"\"-- Hub: {hub['table_name']}\n",
    "-- datavault4dbt v1.17.0 | Snowflake | Generated by gokulram.krishnan\n",
    "{{% set yaml_metadata -%}}\n",
    "source_model: ref('stg_{entity.lower()}')\n",
    "src_pk: '{hub['hash_key']}'\n",
    "src_nk: '{hub['business_key']}'\n",
    "src_ldts: '{hub['load_date_col']}'\n",
    "src_source: '{hub['record_src_col']}'\n",
    "{{%- endset %}}\n",
    "{{%- set metadata_dict = fromyaml(yaml_metadata) -%}}\n",
    "\n",
    "{{{{ datavault4dbt.hub(\n",
    "    source_model=metadata_dict['source_model'],\n",
    "    src_pk=metadata_dict['src_pk'],\n",
    "    src_nk=metadata_dict['src_nk'],\n",
    "    src_ldts=metadata_dict['src_ldts'],\n",
    "    src_source=metadata_dict['src_source']\n",
    ") }}}}\n",
    "\"\"\"\n",
    "        fname = dbt_dir / \"models\" / \"raw_vault\" / f\"hub_{entity.lower()}.sql\"\n",
    "        fname.write_text(hub_sql)\n",
    "        generated[\"hubs\"].append(str(fname))\n",
    "        schema_yml[\"models\"].append({\n",
    "            \"name\": f\"hub_{entity.lower()}\",\n",
    "            \"description\": f\"Data Vault 2.0 Hub for {entity}\",\n",
    "            \"columns\": [\n",
    "                {\"name\": hub[\"hash_key\"],       \"description\": \"Hub hash key\",     \"tests\": [\"not_null\",\"unique\"]},\n",
    "                {\"name\": hub[\"business_key\"],   \"description\": \"Business key\",     \"tests\": [\"not_null\"]},\n",
    "                {\"name\": hub[\"load_date_col\"],  \"description\": \"Load date\",        \"tests\": [\"not_null\"]},\n",
    "                {\"name\": hub[\"record_src_col\"], \"description\": \"Record source\",    \"tests\": [\"not_null\"]},\n",
    "            ]\n",
    "        })\n",
    "\n",
    "    # ── Link models ───────────────────────────────────────────────────────────\n",
    "    for lnk in dv_model[\"links\"]:\n",
    "        lnk_name   = lnk[\"table_name\"].replace(\"LNK_\",\"\").lower()\n",
    "        src_tables = [f\"stg_{e.lower()}\" for e in lnk[\"entities\"]]\n",
    "        lnk_sql    = f\"\"\"-- Link: {lnk['table_name']}\n",
    "-- datavault4dbt v1.17.0 | Snowflake | Generated by gokulram.krishnan\n",
    "{{% set yaml_metadata -%}}\n",
    "source_model: {src_tables}\n",
    "src_pk: '{lnk['hash_key']}'\n",
    "src_fk:\n",
    "  - {chr(10) + '  - '.join(lnk['fk_hash_keys'])}\n",
    "src_ldts: 'LOAD_DATE'\n",
    "src_source: 'RECORD_SOURCE'\n",
    "{{%- endset %}}\n",
    "{{%- set metadata_dict = fromyaml(yaml_metadata) -%}}\n",
    "\n",
    "{{{{ datavault4dbt.link(\n",
    "    source_model=metadata_dict['source_model'],\n",
    "    src_pk=metadata_dict['src_pk'],\n",
    "    src_fk=metadata_dict['src_fk'],\n",
    "    src_ldts=metadata_dict['src_ldts'],\n",
    "    src_source=metadata_dict['src_source']\n",
    ") }}}}\n",
    "\"\"\"\n",
    "        fname = dbt_dir / \"models\" / \"raw_vault\" / f\"lnk_{lnk_name}.sql\"\n",
    "        fname.write_text(lnk_sql)\n",
    "        generated[\"links\"].append(str(fname))\n",
    "\n",
    "    # ── Satellite models ──────────────────────────────────────────────────────\n",
    "    for sat in dv_model[\"satellites\"]:\n",
    "        entity  = sat[\"parent_hub\"].replace(\"HUB_\",\"\")\n",
    "        sat_name = sat[\"table_name\"].lower()\n",
    "        sat_sql  = f\"\"\"-- Satellite: {sat['table_name']}\n",
    "-- datavault4dbt v1.17.0 | Snowflake | Generated by gokulram.krishnan\n",
    "{{% set yaml_metadata -%}}\n",
    "source_model: ref('stg_{entity.lower()}')\n",
    "src_pk: '{sat['hash_key']}'\n",
    "src_hashdiff: '{sat['hash_diff']}'\n",
    "src_payload:\n",
    "  - {chr(10) + '  - '.join(sat['descriptive_cols'])}\n",
    "src_ldts: '{sat['load_date_col']}'\n",
    "src_source: '{sat['record_src_col']}'\n",
    "{{%- endset %}}\n",
    "{{%- set metadata_dict = fromyaml(yaml_metadata) -%}}\n",
    "\n",
    "{{{{ datavault4dbt.sat(\n",
    "    source_model=metadata_dict['source_model'],\n",
    "    src_pk=metadata_dict['src_pk'],\n",
    "    src_hashdiff=metadata_dict['src_hashdiff'],\n",
    "    src_payload=metadata_dict['src_payload'],\n",
    "    src_ldts=metadata_dict['src_ldts'],\n",
    "    src_source=metadata_dict['src_source']\n",
    ") }}}}\n",
    "\"\"\"\n",
    "        fname = dbt_dir / \"models\" / \"raw_vault\" / f\"{sat_name}.sql\"\n",
    "        fname.write_text(sat_sql)\n",
    "        generated[\"satellites\"].append(str(fname))\n",
    "        schema_yml[\"models\"].append({\n",
    "            \"name\": sat_name,\n",
    "            \"description\": f\"Data Vault 2.0 Satellite for {entity}\",\n",
    "        })\n",
    "\n",
    "    schema_path = dbt_dir / \"models\" / \"raw_vault\" / \"schema.yml\"\n",
    "    schema_path.write_text(yaml.dump(schema_yml, sort_keys=False))\n",
    "    generated[\"configs\"].append(str(schema_path))\n",
    "\n",
    "    log(\"Agent4\", f\"✅ DBT files: {len(generated['staging'])} staging | \"\n",
    "        f\"{len(generated['hubs'])} hubs | {len(generated['links'])} links | \"\n",
    "        f\"{len(generated['satellites'])} satellites | {len(generated['configs'])} configs\")\n",
    "    return generated\n",
    "\n",
    "\n",
    "DBT_FILES = run_agent4_dbt_generator(MAPPINGS, DV_MODEL)\n",
    "\n",
    "t2 = Table(title=\"Generated DBT Files\")\n",
    "t2.add_column(\"Layer\", style=\"cyan\"); t2.add_column(\"Files\", style=\"green\")\n",
    "for layer, files in DBT_FILES.items():\n",
    "    for f in files:\n",
    "        t2.add_row(layer.upper(), Path(f).name)\n",
    "console.print(t2)"
   ]
