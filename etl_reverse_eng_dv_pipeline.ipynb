   "source": [
    "import warnings, os, json, hashlib, re, yaml\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from pathlib import Path\n",
    "from datetime import datetime\n",
    "from collections import defaultdict\n",
    "from lxml import etree\n",
    "from jinja2 import Template\n",
    "from rich.console import Console\n",
    "from rich.table import Table\n",
    "\n",
    "console = Console()\n",
    "RUN_TS  = datetime.utcnow()\n",
    "OUTPUT_DIR = Path(\"dv_pipeline_output\")\n",
    "OUTPUT_DIR.mkdir(exist_ok=True)\n",
    "for sub in [\"sttm\",\"dbt/models/staging\",\"dbt/models/raw_vault\",\n",
    "            \"dbt/models/business_vault\",\"dbt/macros\",\n",
    "            \"data_vault\",\"profiling\",\"reconciliation\",\"data_quality\"]:\n",
    "    (OUTPUT_DIR / sub).mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "def log(agent: str, msg: str):\n",
    "    console.print(f\"[bold cyan][{agent}][/bold cyan] {msg}\")\n",
    "\n",
    "def sha256_key(*parts) -> str:\n",
    "    \"\"\"Generate a deterministic hash key from parts — used for DV hash keys.\"\"\"\n",
    "    combined = \"|\".join(str(p).upper().strip() for p in parts)\n",
    "    return hashlib.sha256(combined.encode()).hexdigest().upper()[:32]\n",
    "\n",
    "print(\"✅ Imports OK — output dir:\", OUTPUT_DIR.resolve())"
   ]
