   "source": [
    "from ydata_profiling import ProfileReport\n",
    "from presidio_analyzer import AnalyzerEngine, RecognizerRegistry\n",
    "from presidio_analyzer.nlp_engine import NlpEngineProvider\n",
    "from presidio_analyzer.predefined_recognizers import (\n",
    "    EmailRecognizer, PhoneRecognizer, CreditCardRecognizer,\n",
    "    IpRecognizer, UsSsnRecognizer, DateRecognizer, SpacyRecognizer,\n",
    ")\n",
    "import spacy\n",
    "\n",
    "def build_presidio_analyzer():\n",
    "    installed = spacy.util.get_installed_models()\n",
    "    model = \"en_core_web_lg\" if \"en_core_web_lg\" in installed else \\\n",
    "            \"en_core_web_md\" if \"en_core_web_md\" in installed else \"en_core_web_sm\"\n",
    "    nlp_engine = NlpEngineProvider(nlp_configuration={\n",
    "        \"nlp_engine_name\": \"spacy\",\n",
    "        \"models\": [{\"lang_code\": \"en\", \"model_name\": model}]\n",
    "    }).create_engine()\n",
    "    registry = RecognizerRegistry()\n",
    "    for rec in [EmailRecognizer, PhoneRecognizer, CreditCardRecognizer,\n",
    "                IpRecognizer, UsSsnRecognizer, DateRecognizer]:\n",
    "        registry.add_recognizer(rec(supported_language=\"en\"))\n",
    "    registry.add_recognizer(SpacyRecognizer(\n",
    "        supported_language=\"en\", supported_entities=[\"PERSON\",\"LOCATION\"], ner_strength=0.85\n",
    "    ))\n",
    "    return AnalyzerEngine(nlp_engine=nlp_engine, registry=registry, supported_languages=[\"en\"])\n",
    "\n",
    "\n",
    "def run_agent5_profiler(mappings: list) -> dict:\n",
    "    \"\"\"\n",
    "    Agent 5: Profile source data reconstructed from mapping metadata.\n",
    "    For real usage, replace synthetic_df with actual Snowflake/source data.\n",
    "    \"\"\"\n",
    "    from faker import Faker\n",
    "    import random\n",
    "    fake = Faker(); Faker.seed(42); random.seed(42)\n",
    "\n",
    "    analyzer    = build_presidio_analyzer()\n",
    "    profile_out = {}\n",
    "\n",
    "    ENTITY_THRESHOLDS = {\n",
    "        \"EMAIL_ADDRESS\": 0.5, \"US_SSN\": 0.5, \"PHONE_NUMBER\": 0.5,\n",
    "        \"CREDIT_CARD\":   0.5, \"IP_ADDRESS\": 0.5, \"DATE_TIME\": 0.6,\n",
    "        \"PERSON\":        0.7, \"LOCATION\": 0.7,\n",
    "    }\n",
    "\n",
    "    for m in mappings:\n",
    "        entity = m[\"target_table\"].split(\".\")[-1].upper()\n",
    "        log(\"Agent5\", f\"Profiling {entity}...\")\n",
    "\n",
    "        # Build synthetic DataFrame from mapping column definitions\n",
    "        N = 100\n",
    "        data = {}\n",
    "        for col in m[\"columns\"]:\n",
    "            cname = col[\"tgt\"]; dtype = col[\"dtype\"].upper()\n",
    "            if \"DATE\" in dtype or \"TIME\" in dtype:\n",
    "                data[cname] = [str(fake.date_of_birth()) for _ in range(N)]\n",
    "            elif \"NUMBER\" in dtype or \"FLOAT\" in dtype or \"INT\" in dtype:\n",
    "                data[cname] = [round(random.uniform(0, 100000), 2) for _ in range(N)]\n",
    "            elif \"EMAIL\" in cname.upper():\n",
    "                data[cname] = [fake.email() for _ in range(N)]\n",
    "            elif \"PHONE\" in cname.upper():\n",
    "                data[cname] = [fake.phone_number() for _ in range(N)]\n",
    "            elif \"SSN\" in cname.upper():\n",
    "                data[cname] = [fake.ssn() for _ in range(N)]\n",
    "            elif \"NAME\" in cname.upper():\n",
    "                data[cname] = [fake.name() for _ in range(N)]\n",
    "            else:\n",
    "                data[cname] = [fake.word() for _ in range(N)]\n",
    "\n",
    "        df = pd.DataFrame(data)\n",
    "\n",
    "        # ydata profiling\n",
    "        prof  = ProfileReport(df, title=entity, minimal=True)\n",
    "        desc  = prof.get_description()\n",
    "        tstats= desc.table\n",
    "\n",
    "        # PII scan\n",
    "        pii_summary = {}\n",
    "        for col in df.select_dtypes(include=[\"object\"]).columns:\n",
    "            detections = []\n",
    "            for val in df[col].dropna():\n",
    "                results = analyzer.analyze(text=str(val), language=\"en\")\n",
    "                for r in results:\n",
    "                    if r.score >= ENTITY_THRESHOLDS.get(r.entity_type, 0.5):\n",
    "                        detections.append((r.entity_type, r.score))\n",
    "            if detections:\n",
    "                entities   = list({e for e,_ in detections})\n",
    "                scores     = [s for _,s in detections]\n",
    "                pii_summary[col] = {\n",
    "                    \"is_pii\":   True,\n",
    "                    \"entities\": entities,\n",
    "                    \"avg_conf\": round(float(np.mean(scores)), 4),\n",
    "                    \"max_conf\": round(float(np.max(scores)), 4),\n",
    "                }\n",
    "\n",
    "        profile_out[entity] = {\n",
    "            \"n_rows\":          int(tstats.get(\"n\", 0)),\n",
    "            \"n_cols\":          int(tstats.get(\"n_var\", 0)),\n",
    "            \"pct_missing\":     round(float(tstats.get(\"p_cells_missing\", 0))*100, 4),\n",
    "            \"n_duplicates\":    int(tstats.get(\"n_duplicates\", 0)),\n",
    "            \"pii_columns\":     pii_summary,\n",
    "            \"n_pii_columns\":   len(pii_summary),\n",
    "        }\n",
    "\n",
    "        # Save HTML report\n",
    "        rpt_path = OUTPUT_DIR / \"profiling\" / f\"profile_{entity.lower()}.html\"\n",
    "        prof.to_file(rpt_path)\n",
    "        log(\"Agent5\", f\"  Profile report → {rpt_path}\")\n",
    "\n",
    "    out = OUTPUT_DIR / \"profiling\" / \"profiling_summary.json\"\n",
    "    out.write_text(json.dumps(profile_out, indent=2))\n",
    "    log(\"Agent5\", f\"✅ Profiling complete → {out}\")\n",
    "    return profile_out\n",
    "\n",
    "\n",
    "PROFILE_RESULTS = run_agent5_profiler(MAPPINGS)\n",
    "\n",
    "t3 = Table(title=\"Profiling Summary\")\n",
    "t3.add_column(\"Entity\", style=\"cyan\"); t3.add_column(\"Rows\"); t3.add_column(\"Cols\")\n",
    "t3.add_column(\"Missing%\"); t3.add_column(\"PII Cols\", style=\"red\")\n",
    "for entity, p in PROFILE_RESULTS.items():\n",
    "    t3.add_row(entity, str(p['n_rows']), str(p['n_cols']),\n",
    "               str(p['pct_missing']), str(p['n_pii_columns']))\n",
    "console.print(t3)"
   ]
