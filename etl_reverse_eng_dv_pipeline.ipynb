   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "# Agent 1 — Reverse Engineer\n",
    "Parses DataStage `.dsx`/`.xml` and Informatica `.xml`/`.ipc` files into a unified mapping schema."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def parse_datastage_file(filepath: str) -> list:\n",
    "    \"\"\"\n",
    "    Reverse engineer a DataStage .dsx/.xml export.\n",
    "    Extracts: job name, source/target stages, column mappings, transformations.\n",
    "    Returns list of mapping dicts in unified schema.\n",
    "    \"\"\"\n",
    "    mappings = []\n",
    "    tree     = etree.parse(filepath)\n",
    "    root     = tree.getroot()\n",
    "    ns       = {\"ds\": \"com.ibm.datastage.ai.dtm.ds\"}\n",
    "\n",
    "    # DataStage DSX jobs are wrapped in <DSExportedObjects>\n",
    "    jobs = root.findall(\".//Job\") or root.findall(\".//DSJobDef\")\n",
    "\n",
    "    for job in jobs:\n",
    "        job_name = job.get(\"name\", job.get(\"Identifier\", \"UNKNOWN_JOB\"))\n",
    "\n",
    "        # Extract stages\n",
    "        stages       = {}\n",
    "        source_table = \"UNKNOWN_SOURCE\"\n",
    "        target_table = \"UNKNOWN_TARGET\"\n",
    "\n",
    "        for stage in job.findall(\".//Stage\"):\n",
    "            stype = stage.get(\"type\", stage.get(\"StageType\", \"\"))\n",
    "            sname = stage.get(\"name\", stage.get(\"Identifier\", \"\"))\n",
    "            if \"Source\" in stype or \"DB2\" in stype or \"Oracle\" in stype or \"ODBC\" in stype:\n",
    "                tbl = stage.findtext(\".//Property[@name='TableName']\") or sname\n",
    "                source_table = tbl\n",
    "            elif \"Target\" in stype or \"WriteDB\" in stype:\n",
    "                tbl = stage.findtext(\".//Property[@name='TableName']\") or sname\n",
    "                target_table = tbl\n",
    "\n",
    "        # Extract column-level lineage from derivations\n",
    "        columns = []\n",
    "        for col in job.findall(\".//Column\") + job.findall(\".//DSField\"):\n",
    "            src_col   = col.get(\"sourceColumn\", col.get(\"name\", \"\"))\n",
    "            tgt_col   = col.get(\"name\", src_col)\n",
    "            dtype     = col.get(\"datatype\", col.get(\"SqlType\", \"VARCHAR\"))\n",
    "            derivation= col.get(\"derivation\", \"DIRECT\")\n",
    "            is_pk     = col.get(\"key\", \"false\").lower() == \"true\"\n",
    "            nullable  = col.get(\"nullable\", \"true\").lower() == \"true\"\n",
    "            if src_col:\n",
    "                columns.append({\n",
    "                    \"src\": src_col, \"tgt\": tgt_col,\n",
    "                    \"dtype\": dtype, \"pk\": is_pk,\n",
    "                    \"nullable\": nullable,\n",
    "                    \"transformation\": derivation if derivation != src_col else \"DIRECT\"\n",
    "                })\n",
    "\n",
    "        if columns:\n",
    "            mappings.append({\n",
    "                \"mapping_name\":  job_name,\n",
    "                \"tool\":          \"DataStage\",\n",
    "                \"source_table\":  source_table,\n",
    "                \"target_table\":  target_table,\n",
    "                \"load_strategy\": \"UNKNOWN\",\n",
    "                \"columns\":       columns\n",
    "            })\n",
    "\n",
    "    log(\"Agent1\", f\"DataStage: parsed {len(mappings)} mapping(s) from {filepath}\")\n",
    "    return mappings\n",
    "\n",
    "\n",
    "def parse_informatica_file(filepath: str) -> list:\n",
    "    \"\"\"\n",
    "    Reverse engineer an Informatica PowerCenter .xml export.\n",
    "    Extracts: mapping name, source/target definitions, transformations.\n",
    "    Returns list of mapping dicts in unified schema.\n",
    "    \"\"\"\n",
    "    mappings = []\n",
    "    tree     = etree.parse(filepath)\n",
    "    root     = tree.getroot()\n",
    "\n",
    "    for mapping in root.findall(\".//MAPPING\"):\n",
    "        mapping_name = mapping.get(\"NAME\", \"UNKNOWN_MAPPING\")\n",
    "        source_table = \"UNKNOWN_SOURCE\"\n",
    "        target_table = \"UNKNOWN_TARGET\"\n",
    "        columns      = []\n",
    "\n",
    "        # Source/Target definitions\n",
    "        for instance in mapping.findall(\".//INSTANCE\"):\n",
    "            itype = instance.get(\"TYPE\", \"\")\n",
    "            iname = instance.get(\"NAME\", \"\")\n",
    "            if itype == \"SOURCE\":\n",
    "                src_def = root.find(f\".//SOURCE[@NAME='{instance.get('TRANSFORMATION_NAME', iname)}']\") \n",
    "                if src_def is not None:\n",
    "                    source_table = f\"{src_def.get('DATABASETYPE','')}.{src_def.get('NAME','')}\"\n",
    "            elif itype == \"TARGET\":\n",
    "                tgt_def = root.find(f\".//TARGET[@NAME='{instance.get('TRANSFORMATION_NAME', iname)}']\") \n",
    "                if tgt_def is not None:\n",
    "                    target_table = f\"{tgt_def.get('DATABASETYPE','')}.{tgt_def.get('NAME','')}\"\n",
    "\n",
    "        # Column mappings from CONNECTOR elements\n",
    "        col_map = defaultdict(dict)\n",
    "        for conn in mapping.findall(\".//CONNECTOR\"):\n",
    "            tgt_col = conn.get(\"TOFIELD\", \"\")\n",
    "            src_col = conn.get(\"FROMFIELD\", tgt_col)\n",
    "            if tgt_col:\n",
    "                col_map[tgt_col][\"src\"]  = src_col\n",
    "                col_map[tgt_col][\"tgt\"]  = tgt_col\n",
    "\n",
    "        # Enrich with field metadata from TARGET definition\n",
    "        for tgt_def in root.findall(\".//TARGET\"):\n",
    "            for field in tgt_def.findall(\".//TARGETFIELD\"):\n",
    "                fname  = field.get(\"NAME\", \"\")\n",
    "                entry  = col_map.get(fname, {\"src\": fname, \"tgt\": fname})\n",
    "                entry.update({\n",
    "                    \"dtype\":          field.get(\"DATATYPE\", \"VARCHAR\"),\n",
    "                    \"pk\":             field.get(\"KEYTYPE\", \"NOT_A_KEY\") == \"PRIMARY KEY\",\n",
    "                    \"nullable\":       field.get(\"NULLABLE\", \"YES\") == \"YES\",\n",
    "                    \"transformation\": entry.get(\"transformation\", \"DIRECT\")\n",
    "                })\n",
    "                columns.append(entry)\n",
    "\n",
    "        if columns:\n",
    "            mappings.append({\n",
    "                \"mapping_name\":  mapping_name,\n",
    "                \"tool\":          \"Informatica\",\n",
    "                \"source_table\":  source_table,\n",
    "                \"target_table\":  target_table,\n",
    "                \"load_strategy\": \"UNKNOWN\",\n",
    "                \"columns\":       columns\n",
    "            })\n",
    "\n",
    "    log(\"Agent1\", f\"Informatica: parsed {len(mappings)} mapping(s) from {filepath}\")\n",
    "    return mappings\n",
    "\n",
    "\n",
    "def run_agent1_reverse_engineer(ds_files, inf_files, use_synthetic=False, synthetic_mappings=None):\n",
    "    \"\"\"Agent 1 orchestrator — parses all input files into unified mapping list.\"\"\"\n",
    "    all_mappings = []\n",
    "\n",
    "    if use_synthetic:\n",
    "        log(\"Agent1\", \"Using synthetic demo mappings\")\n",
    "        return synthetic_mappings\n",
    "\n",
    "    for f in ds_files:\n",
    "        try:\n",
    "            all_mappings.extend(parse_datastage_file(f))\n",
    "        except Exception as e:\n",
    "            log(\"Agent1\", f\"⚠️  Failed to parse DataStage file {f}: {e}\")\n",
    "\n",
    "    for f in inf_files:\n",
    "        try:\n",
    "            all_mappings.extend(parse_informatica_file(f))\n",
    "        except Exception as e:\n",
    "            log(\"Agent1\", f\"⚠️  Failed to parse Informatica file {f}: {e}\")\n",
    "\n",
    "    log(\"Agent1\", f\"✅ Total mappings extracted: {len(all_mappings)}\")\n",
    "    out = OUTPUT_DIR / \"sttm\" / \"raw_mappings.json\"\n",
    "    out.write_text(json.dumps(all_mappings, indent=2))\n",
    "    log(\"Agent1\", f\"Saved → {out}\")\n",
    "    return all_mappings\n",
    "\n",
    "\n",
    "# ── Run Agent 1 ───────────────────────────────────────────────────────────────\n",
    "MAPPINGS = run_agent1_reverse_engineer(\n",
    "    DATASTAGE_FILES, INFORMATICA_FILES,\n",
    "    use_synthetic=USE_SYNTHETIC_DEMO,\n",
    "    synthetic_mappings=SYNTHETIC_MAPPINGS\n",
    ")\n",
    "print(f\"\\n✅ Agent 1 complete — {len(MAPPINGS)} mapping(s) ready for downstream agents\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "# Agent 2 — STTM Generator\n",
    "Produces a Source-to-Target Mapping document in Excel and JSON."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def run_agent2_sttm(mappings: list) -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    Agent 2: Generate Source-to-Target Mapping document.\n",
    "    Outputs: STTM Excel workbook + JSON summary.\n",
    "    \"\"\"\n",
    "    rows = []\n",
    "    for m in mappings:\n",
    "        for col in m[\"columns\"]:\n",
    "            rows.append({\n",
    "                \"Mapping Name\":      m[\"mapping_name\"],\n",
    "                \"ETL Tool\":          m[\"tool\"],\n",
    "                \"Load Strategy\":     m[\"load_strategy\"],\n",
    "                \"Source Table\":      m[\"source_table\"],\n",
    "                \"Source Column\":     col[\"src\"],\n",
    "                \"Target Table\":      m[\"target_table\"],\n",
    "                \"Target Column\":     col[\"tgt\"],\n",
    "                \"Data Type\":         col[\"dtype\"],\n",
    "                \"Primary Key\":       \"Yes\" if col[\"pk\"] else \"No\",\n",
    "                \"Nullable\":          \"Yes\" if col[\"nullable\"] else \"No\",\n",
    "                \"Transformation\":    col[\"transformation\"],\n",
    "                \"DV Entity Type\":    \"\",   # filled by Agent 3\n",
    "                \"DV Table\":          \"\",   # filled by Agent 3\n",
    "                \"DQ Rule\":           \"\",   # filled by Agent 7\n",
    "                \"Notes\":             \"\",\n",
    "            })\n",
    "\n",
    "    sttm_df = pd.DataFrame(rows)\n",
    "\n",
    "    # ── Excel output ──────────────────────────────────────────────────────────\n",
    "    excel_path = OUTPUT_DIR / \"sttm\" / \"STTM.xlsx\"\n",
    "    with pd.ExcelWriter(excel_path, engine=\"xlsxwriter\") as writer:\n",
    "        sttm_df.to_excel(writer, sheet_name=\"STTM\", index=False)\n",
    "        wb  = writer.book\n",
    "        ws  = writer.sheets[\"STTM\"]\n",
    "        hdr = wb.add_format({\"bold\": True, \"bg_color\": \"#003366\", \"font_color\": \"white\", \"border\": 1})\n",
    "        for col_idx, col_name in enumerate(sttm_df.columns):\n",
    "            ws.write(0, col_idx, col_name, hdr)\n",
    "            ws.set_column(col_idx, col_idx, max(len(col_name)+4, 18))\n",
    "\n",
    "        # Summary sheet\n",
    "        summary = pd.DataFrame([\n",
    "            {\"Metric\": \"Total Mappings\",         \"Value\": len(mappings)},\n",
    "            {\"Metric\": \"Total Columns Mapped\",   \"Value\": len(rows)},\n",
    "            {\"Metric\": \"DataStage Mappings\",      \"Value\": sum(1 for m in mappings if m[\"tool\"]==\"DataStage\")},\n",
    "            {\"Metric\": \"Informatica Mappings\",    \"Value\": sum(1 for m in mappings if m[\"tool\"]==\"Informatica\")},\n",
    "            {\"Metric\": \"Full Load Mappings\",      \"Value\": sum(1 for m in mappings if m[\"load_strategy\"]==\"FULL\")},\n",
    "            {\"Metric\": \"Incremental Mappings\",    \"Value\": sum(1 for m in mappings if m[\"load_strategy\"]==\"INCREMENTAL\")},\n",
    "            {\"Metric\": \"PK Columns\",              \"Value\": sum(1 for r in rows if r[\"Primary Key\"]==\"Yes\")},\n",
    "            {\"Metric\": \"Direct Mappings\",         \"Value\": sum(1 for r in rows if r[\"Transformation\"]==\"DIRECT\")},\n",
    "            {\"Metric\": \"Transformed Columns\",     \"Value\": sum(1 for r in rows if r[\"Transformation\"]!=\"DIRECT\")},\n",
    "            {\"Metric\": \"Run Timestamp (UTC)\",     \"Value\": str(RUN_TS)},\n",
    "        ])\n",
    "        summary.to_excel(writer, sheet_name=\"Summary\", index=False)\n",
    "\n",
    "    log(\"Agent2\", f\"✅ STTM Excel saved → {excel_path}\")\n",
    "\n",
    "    # ── JSON output ───────────────────────────────────────────────────────────\n",
    "    json_path = OUTPUT_DIR / \"sttm\" / \"STTM.json\"\n",
    "    json_path.write_text(json.dumps(rows, indent=2))\n",
    "    log(\"Agent2\", f\"✅ STTM JSON saved  → {json_path}\")\n",
    "\n",
    "    return sttm_df\n",
    "\n",
    "\n",
    "STTM_DF = run_agent2_sttm(MAPPINGS)\n",
    "display(STTM_DF.head(10))"
   ]
