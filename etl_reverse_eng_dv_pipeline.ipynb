   "source": [
    "---\n",
    "# Agent 7 — Data Quality Rule Engine\n",
    "Generates dbt tests, Great Expectations suites, and SQL-based DQ checks."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DQ_RULES = {\n",
    "    \"not_null\":          {\"applies_to\": [\"pk\", \"non_nullable\"], \"dbt_test\": \"not_null\"},\n",
    "    \"unique\":            {\"applies_to\": [\"pk\"],                  \"dbt_test\": \"unique\"},\n",
    "    \"accepted_values\":   {\"applies_to\": [\"status\", \"code\"],      \"dbt_test\": \"accepted_values\"},\n",
    "    \"date_format\":       {\"applies_to\": [\"date\", \"timestamp\"],   \"dbt_test\": \"dbt_utils.expression_is_true\"},\n",
    "    \"positive_values\":   {\"applies_to\": [\"amount\", \"price\"],     \"dbt_test\": \"dbt_utils.expression_is_true\"},\n",
    "    \"referential_int\":   {\"applies_to\": [\"fk\"],                  \"dbt_test\": \"relationships\"},\n",
    "    \"no_future_dates\":   {\"applies_to\": [\"date\"],                \"dbt_test\": \"dbt_utils.expression_is_true\"},\n",
    "    \"string_length\":     {\"applies_to\": [\"varchar\"],             \"dbt_test\": \"dbt_utils.expression_is_true\"},\n",
    "    \"pattern_match\":     {\"applies_to\": [\"email\", \"phone\"],      \"dbt_test\": \"dbt_utils.expression_is_true\"},\n",
    "    \"no_duplicates\":     {\"applies_to\": [\"pk\"],                  \"dbt_test\": \"unique\"},\n",
    "    \"load_date_current\": {\"applies_to\": [\"load_date\"],           \"dbt_test\": \"dbt_utils.expression_is_true\"},\n",
    "}\n",
    "\n",
    "\n",
    "def infer_dq_rules(col: dict, m: dict) -> list:\n",
    "    \"\"\"Infer applicable DQ rules for a column based on metadata.\"\"\"\n",
    "    rules = []\n",
    "    cname  = col[\"tgt\"].upper()\n",
    "    dtype  = col[\"dtype\"].upper()\n",
    "\n",
    "    if col[\"pk\"]:\n",
    "        rules += [\"not_null\", \"unique\"]\n",
    "    if not col[\"nullable\"]:\n",
    "        rules.append(\"not_null\")\n",
    "    if \"DATE\" in dtype or \"TIME\" in dtype:\n",
    "        rules += [\"date_format\", \"no_future_dates\"]\n",
    "    if any(x in cname for x in [\"AMOUNT\",\"PRICE\",\"SALARY\",\"COST\"]):\n",
    "        rules.append(\"positive_values\")\n",
    "    if \"EMAIL\" in cname:\n",
    "        rules.append(\"pattern_match\")\n",
    "    if \"STATUS\" in cname or \"CODE\" in cname or \"TYPE\" in cname:\n",
    "        rules.append(\"accepted_values\")\n",
    "    if cname in [\"LOAD_DATE\",\"LOAD_DT\"]:\n",
    "        rules.append(\"load_date_current\")\n",
    "    if any(x in cname for x in [\"_ID\",\"_KEY\"]) and not col[\"pk\"]:\n",
    "        rules.append(\"referential_int\")\n",
    "\n",
    "    return list(set(rules))\n",
    "\n",
    "\n",
    "def run_agent7_data_quality(mappings: list, dv_model: dict) -> dict:\n",
    "    \"\"\"\n",
    "    Agent 7: Generate dbt schema tests, SQL DQ checks, and a DQ report.\n",
    "    \"\"\"\n",
    "    dq_report = []\n",
    "\n",
    "    for m in mappings:\n",
    "        entity   = m[\"target_table\"].split(\".\")[-1].upper()\n",
    "        model_nm = f\"stg_{entity.lower()}\"\n",
    "        col_tests= []\n",
    "        sql_checks = []\n",
    "\n",
    "        for col in m[\"columns\"]:\n",
    "            rules  = infer_dq_rules(col, m)\n",
    "            cname  = col[\"tgt\"]\n",
    "            dtype  = col[\"dtype\"].upper()\n",
    "            tests  = []\n",
    "\n",
    "            for rule in rules:\n",
    "                if rule == \"not_null\":\n",
    "                    tests.append(\"not_null\")\n",
    "                    sql_checks.append(\n",
    "                        f\"-- DQ: NOT NULL on {cname}\\n\"\n",
    "                        f\"SELECT COUNT(*) AS fail_count FROM {{{{ ref('{model_nm}') }}}}\\n\"\n",
    "                        f\"WHERE {cname} IS NULL;\"\n",
    "                    )\n",
    "                elif rule == \"unique\":\n",
    "                    tests.append(\"unique\")\n",
    "                    sql_checks.append(\n",
    "                        f\"-- DQ: UNIQUE on {cname}\\n\"\n",
    "                        f\"SELECT {cname}, COUNT(*) AS cnt FROM {{{{ ref('{model_nm}') }}}}\\n\"\n",
    "                        f\"GROUP BY {cname} HAVING COUNT(*) > 1;\"\n",
    "                    )\n",
    "                elif rule == \"positive_values\":\n",
    "                    tests.append({\"dbt_utils.expression_is_true\": {\"expression\": f\"{cname} >= 0\"}})\n",
    "                    sql_checks.append(\n",
    "                        f\"-- DQ: POSITIVE on {cname}\\n\"\n",
    "                        f\"SELECT COUNT(*) AS fail_count FROM {{{{ ref('{model_nm}') }}}}\\n\"\n",
    "                        f\"WHERE {cname} < 0;\"\n",
    "                    )\n",
    "                elif rule == \"no_future_dates\":\n",
    "                    tests.append({\"dbt_utils.expression_is_true\": {\"expression\": f\"{cname} <= CURRENT_DATE\"}})\n",
    "                    sql_checks.append(\n",
    "                        f\"-- DQ: NO FUTURE DATES on {cname}\\n\"\n",
    "                        f\"SELECT COUNT(*) AS fail_count FROM {{{{ ref('{model_nm}') }}}}\\n\"\n",
    "                        f\"WHERE {cname} > CURRENT_DATE;\"\n",
    "                    )\n",
    "                elif rule == \"pattern_match\" and \"EMAIL\" in cname.upper():\n",
    "                    tests.append({\"dbt_utils.expression_is_true\": {\n",
    "                        \"expression\": f\"{cname} RLIKE '^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\\\.[A-Za-z]{{2,}}$'\"\n",
    "                    }})\n",
    "                elif rule == \"load_date_current\":\n",
    "                    tests.append({\"dbt_utils.expression_is_true\": {\n",
    "                        \"expression\": f\"{cname} <= CURRENT_TIMESTAMP\"\n",
    "                    }})\n",
    "\n",
    "            if tests:\n",
    "                col_tests.append({\"name\": cname, \"tests\": tests})\n",
    "\n",
    "            dq_report.append({\n",
    "                \"mapping\":     m[\"mapping_name\"],\n",
    "                \"entity\":      entity,\n",
    "                \"column\":      cname,\n",
    "                \"data_type\":   dtype,\n",
    "                \"dq_rules\":    rules,\n",
    "                \"n_rules\":     len(rules),\n",
    "                \"is_critical\": col[\"pk\"] or not col[\"nullable\"],\n",
    "            })\n",
    "\n",
    "        # ── dbt schema YAML with tests ────────────────────────────────────────\n",
    "        dbt_schema = {\n",
    "            \"version\": 2,\n",
    "            \"models\": [{\n",
    "                \"name\":    model_nm,\n",
    "                \"columns\": col_tests\n",
    "            }]\n",
    "        }\n",
    "        schema_path = OUTPUT_DIR / \"dbt\" / \"models\" / \"staging\" / f\"schema_dq_{entity.lower()}.yml\"\n",
    "        schema_path.write_text(yaml.dump(dbt_schema, sort_keys=False))\n",
    "\n",
    "        # ── SQL DQ checks ─────────────────────────────────────────────────────\n",
    "        sql_path = OUTPUT_DIR / \"data_quality\" / f\"dq_{entity.lower()}.sql\"\n",
    "        sql_path.write_text(\"\\n\\n\".join(sql_checks))\n",
    "\n",
    "        log(\"Agent7\", f\"{entity}: {len(col_tests)} columns with DQ rules → {schema_path.name}\")\n",
    "\n",
    "    # ── DQ summary report ─────────────────────────────────────────────────────\n",
    "    dq_df   = pd.DataFrame(dq_report)\n",
    "    rpt_path = OUTPUT_DIR / \"data_quality\" / \"dq_report.xlsx\"\n",
    "    with pd.ExcelWriter(rpt_path, engine=\"xlsxwriter\") as writer:\n",
    "        dq_df.to_excel(writer, sheet_name=\"DQ Rules\", index=False)\n",
    "        critical = dq_df[dq_df[\"is_critical\"] == True]\n",
    "        critical.to_excel(writer, sheet_name=\"Critical Columns\", index=False)\n",
    "\n",
    "        summary = pd.DataFrame([\n",
    "            {\"Metric\": \"Total Columns\",         \"Value\": len(dq_df)},\n",
    "            {\"Metric\": \"Columns with DQ Rules\",  \"Value\": int((dq_df[\"n_rules\"]>0).sum())},\n",
    "            {\"Metric\": \"Critical Columns\",       \"Value\": len(critical)},\n",
    "            {\"Metric\": \"Total DQ Rules Applied\", \"Value\": int(dq_df[\"n_rules\"].sum())},\n",
    "        ])\n",
    "        summary.to_excel(writer, sheet_name=\"Summary\", index=False)\n",
    "\n",
    "    log(\"Agent7\", f\"✅ DQ Report → {rpt_path}\")\n",
    "    return dq_df\n",
    "\n",
    "\n",
    "DQ_DF = run_agent7_data_quality(MAPPINGS, DV_MODEL)\n",
    "display(DQ_DF.head(15))"
   ]
  },
