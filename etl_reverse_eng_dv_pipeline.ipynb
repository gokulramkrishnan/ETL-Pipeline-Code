    "---\n",
    "# Agent 3 — Data Vault 2.0 Modeler\n",
    "Auto-classifies columns into Hubs, Links, Satellites following DV2.0 standards.\n",
    "Aligned to datavault4dbt v1.17.0 naming conventions."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def infer_business_key(columns: list) -> list:\n",
    "    \"\"\"Identify business key columns (PKs or columns ending in _ID/_KEY/_NO/_CODE).\"\"\"\n",
    "    bk_patterns = re.compile(r'(_ID|_KEY|_NO|_CODE|_NUM|_NBR)$', re.IGNORECASE)\n",
    "    return [\n",
    "        c for c in columns\n",
    "        if c[\"pk\"] or bk_patterns.search(c[\"tgt\"])\n",
    "    ]\n",
    "\n",
    "\n",
    "def classify_dv_entities(mappings: list) -> dict:\n",
    "    \"\"\"\n",
    "    Agent 3: Classify each mapping into DV2.0 entities.\n",
    "    Rules:\n",
    "      - Hub     : one business key identified → HUB_<entity>\n",
    "      - Link    : two+ foreign keys pointing to other hubs → LNK_<entity1>_<entity2>\n",
    "      - Satellite: remaining descriptive columns → SAT_<entity>_<source>\n",
    "    Returns dict: {hub: [], link: [], satellite: []}\n",
    "    \"\"\"\n",
    "    dv_model = {\"hubs\": [], \"links\": [], \"satellites\": [], \"staging\": []}\n",
    "\n",
    "    for m in mappings:\n",
    "        cols    = m[\"columns\"]\n",
    "        bk_cols = infer_business_key(cols)\n",
    "        desc_cols = [c for c in cols if c not in bk_cols\n",
    "                     and c[\"tgt\"] not in (\"LOAD_DATE\",\"RECORD_SOURCE\",\"LOAD_DT\",\"REC_SRC\")]\n",
    "        tech_cols = [c for c in cols if c[\"tgt\"] in\n",
    "                     (\"LOAD_DATE\",\"RECORD_SOURCE\",\"LOAD_DT\",\"REC_SRC\",\"HASH_DIFF\")]\n",
    "\n",
    "        # Entity name from target table (e.g. STG.CUSTOMER → CUSTOMER)\n",
    "        entity = m[\"target_table\"].split(\".\")[-1].upper()\n",
    "        src    = m[\"source_table\"].replace(\".\",\"_\").upper()\n",
    "\n",
    "        # ── Staging layer ─────────────────────────────────────────────────────\n",
    "        dv_model[\"staging\"].append({\n",
    "            \"table_name\":     f\"STG_{entity}\",\n",
    "            \"source_mapping\": m[\"mapping_name\"],\n",
    "            \"source_table\":   m[\"source_table\"],\n",
    "            \"load_strategy\":  m[\"load_strategy\"],\n",
    "            \"bk_columns\":     [c[\"tgt\"] for c in bk_cols],\n",
    "            \"all_columns\":    cols,\n",
    "        })\n",
    "\n",
    "        # ── Hub ───────────────────────────────────────────────────────────────\n",
    "        if bk_cols:\n",
    "            hub_name = f\"HUB_{entity}\"\n",
    "            hub_bk   = bk_cols[0][\"tgt\"]  # primary business key\n",
    "            dv_model[\"hubs\"].append({\n",
    "                \"table_name\":     hub_name,\n",
    "                \"entity\":         entity,\n",
    "                \"business_key\":   hub_bk,\n",
    "                \"hash_key\":       f\"HK_{entity}\",\n",
    "                \"source_table\":   m[\"source_table\"],\n",
    "                \"load_date_col\":  \"LOAD_DATE\",\n",
    "                \"record_src_col\": \"RECORD_SOURCE\",\n",
    "            })\n",
    "\n",
    "        # ── Link (when multiple BK columns → FK relationship) ─────────────────\n",
    "        if len(bk_cols) >= 2:\n",
    "            entities_linked = [c[\"tgt\"].replace(\"_ID\",\"\").replace(\"_KEY\",\"\") for c in bk_cols[:2]]\n",
    "            lnk_name = f\"LNK_{'_'.join(entities_linked)}\"\n",
    "            dv_model[\"links\"].append({\n",
    "                \"table_name\":     lnk_name,\n",
    "                \"entities\":       entities_linked,\n",
    "                \"hash_key\":       f\"HK_{lnk_name}\",\n",
    "                \"fk_hash_keys\":   [f\"HK_{e}\" for e in entities_linked],\n",
    "                \"source_table\":   m[\"source_table\"],\n",
    "                \"load_date_col\":  \"LOAD_DATE\",\n",
    "                \"record_src_col\": \"RECORD_SOURCE\",\n",
    "            })\n",
    "\n",
    "        # ── Satellite ─────────────────────────────────────────────────────────\n",
    "        if desc_cols and bk_cols:\n",
    "            sat_name = f\"SAT_{entity}_{src[:20]}\"\n",
    "            dv_model[\"satellites\"].append({\n",
    "                \"table_name\":        sat_name,\n",
    "                \"parent_hub\":        f\"HUB_{entity}\",\n",
    "                \"hash_key\":          f\"HK_{entity}\",\n",
    "                \"hash_diff\":         f\"HD_{entity}\",\n",
    "                \"descriptive_cols\":  [c[\"tgt\"] for c in desc_cols],\n",
    "                \"source_table\":      m[\"source_table\"],\n",
    "                \"load_date_col\":     \"LOAD_DATE\",\n",
    "                \"record_src_col\":    \"RECORD_SOURCE\",\n",
    "            })\n",
    "\n",
    "    # ── Save model JSON ───────────────────────────────────────────────────────\n",
    "    out = OUTPUT_DIR / \"data_vault\" / \"dv_model.json\"\n",
    "    out.write_text(json.dumps(dv_model, indent=2))\n",
    "    log(\"Agent3\", f\"✅ DV2.0 model: {len(dv_model['hubs'])} Hubs | \"\n",
    "        f\"{len(dv_model['links'])} Links | {len(dv_model['satellites'])} Satellites\")\n",
    "    log(\"Agent3\", f\"Saved → {out}\")\n",
    "    return dv_model\n",
    "\n",
    "\n",
    "DV_MODEL = classify_dv_entities(MAPPINGS)\n",
    "\n",
    "# Pretty print model\n",
    "t = Table(title=\"Data Vault 2.0 Model\")\n",
    "t.add_column(\"Layer\", style=\"cyan\")\n",
    "t.add_column(\"Table Name\", style=\"green\")\n",
    "t.add_column(\"Details\")\n",
    "for hub in DV_MODEL[\"hubs\"]:\n",
    "    t.add_row(\"HUB\", hub[\"table_name\"], f\"BK: {hub['business_key']} | HK: {hub['hash_key']}\")\n",
    "for lnk in DV_MODEL[\"links\"]:\n",
    "    t.add_row(\"LINK\", lnk[\"table_name\"], f\"Entities: {', '.join(lnk['entities'])}\")\n",
    "for sat in DV_MODEL[\"satellites\"]:\n",
    "    t.add_row(\"SAT\", sat[\"table_name\"], f\"Parent: {sat['parent_hub']} | Cols: {len(sat['descriptive_cols'])}\")\n",
    "console.print(t)"
   ]
  },
