<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE POWERMART SYSTEM "powrmart.dtd">
<POWERMART CREATION_DATE="04/02/2026 10:00:00" REPOSITORY_VERSION="187.97">
<REPOSITORY NAME="DEV_REPO" VERSION="187" CODEPAGE="UTF-8" DATABASETYPE="Oracle">
<FOLDER NAME="ETL_MAPPINGS" GROUP="" OWNER="admin">

  <SOURCE DBDNAME="OPERATIONAL" NAME="SRC_PRODUCT" DATABASETYPE="Oracle">
    <SOURCEFIELD DATATYPE="number"         LENGTH="10"  NAME="PRODUCT_ID"   NULLABLE="NOT NULL" KEYTYPE="PRIMARY KEY"/>
    <SOURCEFIELD DATATYPE="varchar2"       LENGTH="255" NAME="PRODUCT_NAME" NULLABLE="NULL"     KEYTYPE="NOT A KEY"/>
    <SOURCEFIELD DATATYPE="varchar2"       LENGTH="100" NAME="CATEGORY"     NULLABLE="NULL"     KEYTYPE="NOT A KEY"/>
    <SOURCEFIELD DATATYPE="number"         LENGTH="18"  NAME="UNIT_PRICE"   NULLABLE="NOT NULL" KEYTYPE="NOT A KEY" PRECISION="2"/>
    <SOURCEFIELD DATATYPE="number"         LENGTH="1"   NAME="IS_ACTIVE"    NULLABLE="NOT NULL" KEYTYPE="NOT A KEY"/>
  </SOURCE>

  <SOURCE DBDNAME="OPERATIONAL" NAME="SRC_CUSTOMER" DATABASETYPE="Oracle">
    <SOURCEFIELD DATATYPE="number"   LENGTH="10"  NAME="CUSTOMER_ID"  NULLABLE="NOT NULL" KEYTYPE="PRIMARY KEY"/>
    <SOURCEFIELD DATATYPE="varchar2" LENGTH="100" NAME="FIRST_NAME"   NULLABLE="NULL"     KEYTYPE="NOT A KEY"/>
    <SOURCEFIELD DATATYPE="varchar2" LENGTH="100" NAME="LAST_NAME"    NULLABLE="NULL"     KEYTYPE="NOT A KEY"/>
    <SOURCEFIELD DATATYPE="varchar2" LENGTH="255" NAME="EMAIL"         NULLABLE="NULL"     KEYTYPE="NOT A KEY"/>
    <SOURCEFIELD DATATYPE="varchar2" LENGTH="20"  NAME="PHONE"         NULLABLE="NULL"     KEYTYPE="NOT A KEY"/>
    <SOURCEFIELD DATATYPE="date"     LENGTH="0"   NAME="CREATED_DATE" NULLABLE="NOT NULL" KEYTYPE="NOT A KEY"/>
  </SOURCE>

  <TARGET DBDNAME="DW" NAME="TGT_FACT_ORDER" DATABASETYPE="Snowflake">
    <TARGETFIELD DATATYPE="varchar2" LENGTH="32"  NAME="ORDER_HK"      NULLABLE="NOT NULL" KEYTYPE="PRIMARY KEY"/>
    <TARGETFIELD DATATYPE="varchar2" LENGTH="32"  NAME="CUSTOMER_HK"   NULLABLE="NOT NULL" KEYTYPE="FOREIGN KEY"/>
    <TARGETFIELD DATATYPE="varchar2" LENGTH="32"  NAME="PRODUCT_HK"    NULLABLE="NOT NULL" KEYTYPE="FOREIGN KEY"/>
    <TARGETFIELD DATATYPE="date"     LENGTH="0"   NAME="ORDER_DATE"    NULLABLE="NOT NULL" KEYTYPE="NOT A KEY"/>
    <TARGETFIELD DATATYPE="number"   LENGTH="18"  NAME="ORDER_AMOUNT"  NULLABLE="NULL"     KEYTYPE="NOT A KEY" PRECISION="2"/>
    <TARGETFIELD DATATYPE="timestamp" LENGTH="0"  NAME="LOAD_DATE"     NULLABLE="NOT NULL" KEYTYPE="NOT A KEY"/>
    <TARGETFIELD DATATYPE="varchar2" LENGTH="100" NAME="RECORD_SOURCE" NULLABLE="NOT NULL" KEYTYPE="NOT A KEY"/>
  </TARGET>

  <MAPPING NAME="M_ORDER_FACT_LOAD" ISVALID="YES">

    <TRANSFORMATION NAME="SQ_SRC_ORDER" TYPE="Source Qualifier" ISVALID="YES">
      <TRANSFORMFIELD DATATYPE="number"   LENGTH="10"  NAME="ORDER_ID"     PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="number"   LENGTH="10"  NAME="CUSTOMER_ID"  PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="number"   LENGTH="10"  NAME="PRODUCT_ID"   PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="date"     LENGTH="0"   NAME="ORDER_DATE"   PORTTYPE="OUTPUT"/>
      <TRANSFORMFIELD DATATYPE="number"   LENGTH="18"  NAME="ORDER_AMOUNT" PORTTYPE="OUTPUT" DEFAULTVALUE="NVL(ORDER_AMOUNT, 0)"/>
      <TRANSFORMFIELD DATATYPE="varchar2" LENGTH="50"  NAME="STATUS"       PORTTYPE="OUTPUT"/>
    </TRANSFORMATION>

    <TRANSFORMATION NAME="EXP_HASH_KEYS" TYPE="Expression" ISVALID="YES">
      <TRANSFORMFIELD DATATYPE="varchar2" LENGTH="32" NAME="ORDER_HK"    PORTTYPE="OUTPUT" EXPRESSION="MD5(TO_CHAR(ORDER_ID))"/>
      <TRANSFORMFIELD DATATYPE="varchar2" LENGTH="32" NAME="CUSTOMER_HK" PORTTYPE="OUTPUT" EXPRESSION="MD5(TO_CHAR(CUSTOMER_ID))"/>
      <TRANSFORMFIELD DATATYPE="varchar2" LENGTH="32" NAME="PRODUCT_HK"  PORTTYPE="OUTPUT" EXPRESSION="MD5(TO_CHAR(PRODUCT_ID))"/>
      <TRANSFORMFIELD DATATYPE="timestamp" LENGTH="0" NAME="LOAD_DATE"   PORTTYPE="OUTPUT" EXPRESSION="SYSDATE"/>
      <TRANSFORMFIELD DATATYPE="varchar2" LENGTH="100" NAME="RECORD_SOURCE" PORTTYPE="OUTPUT" EXPRESSION="'ETL_PIPELINE'"/>
    </TRANSFORMATION>

    <TRANSFORMATION NAME="AGG_ORDER_STATS" TYPE="Aggregator" ISVALID="YES">
      <TRANSFORMFIELD DATATYPE="number" LENGTH="18" NAME="TOTAL_AMOUNT" PORTTYPE="OUTPUT" EXPRESSION="SUM(ORDER_AMOUNT)"/>
      <TRANSFORMFIELD DATATYPE="number" LENGTH="10" NAME="ORDER_COUNT"  PORTTYPE="OUTPUT" EXPRESSION="COUNT(ORDER_ID)"/>
    </TRANSFORMATION>

    <CONNECTOR FROMINSTANCE="SQ_SRC_ORDER"  FROMFIELD="ORDER_ID"     TOINSTANCE="EXP_HASH_KEYS" TOFIELD="ORDER_ID"/>
    <CONNECTOR FROMINSTANCE="SQ_SRC_ORDER"  FROMFIELD="CUSTOMER_ID"  TOINSTANCE="EXP_HASH_KEYS" TOFIELD="CUSTOMER_ID"/>
    <CONNECTOR FROMINSTANCE="SQ_SRC_ORDER"  FROMFIELD="PRODUCT_ID"   TOINSTANCE="EXP_HASH_KEYS" TOFIELD="PRODUCT_ID"/>
    <CONNECTOR FROMINSTANCE="SQ_SRC_ORDER"  FROMFIELD="ORDER_AMOUNT" TOINSTANCE="AGG_ORDER_STATS" TOFIELD="ORDER_AMOUNT"/>
    <CONNECTOR FROMINSTANCE="EXP_HASH_KEYS" FROMFIELD="ORDER_HK"     TOINSTANCE="TGT_FACT_ORDER" TOFIELD="ORDER_HK"/>
    <CONNECTOR FROMINSTANCE="EXP_HASH_KEYS" FROMFIELD="CUSTOMER_HK"  TOINSTANCE="TGT_FACT_ORDER" TOFIELD="CUSTOMER_HK"/>
    <CONNECTOR FROMINSTANCE="EXP_HASH_KEYS" FROMFIELD="PRODUCT_HK"   TOINSTANCE="TGT_FACT_ORDER" TOFIELD="PRODUCT_HK"/>
    <CONNECTOR FROMINSTANCE="EXP_HASH_KEYS" FROMFIELD="LOAD_DATE"    TOINSTANCE="TGT_FACT_ORDER" TOFIELD="LOAD_DATE"/>

  </MAPPING>
</FOLDER>
</REPOSITORY>
</POWERMART>
